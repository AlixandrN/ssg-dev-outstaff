generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  email     String?
  topic     String?
  message   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("customers")
}